Subject: [PATCH 2/3] 005-xpdf-4.00-permissions

---
 xpdf-qt/QtPDFCore.cc  | 2 ++
 xpdf-qt/XpdfWidget.cc | 4 ++++
 xpdf/pdfimages.cc     | 4 ++++
 xpdf/pdftohtml.cc     | 2 ++
 xpdf/pdftops.cc       | 4 ++++
 xpdf/pdftotext.cc     | 4 ++++
 6 files changed, 20 insertions(+)

diff --git a/xpdf-qt/QtPDFCore.cc b/xpdf-qt/QtPDFCore.cc
index f98c565..f432be9 100644
--- a/xpdf-qt/QtPDFCore.cc
+++ b/xpdf-qt/QtPDFCore.cc
@@ -494,9 +494,11 @@ QString QtPDFCore::getSelectedTextQString() {
   QString qs;
   int i;
 
+#ifdef ENFORCE_PERMISSIONS
   if (!doc->okToCopy()) {
     return "";
   }
+#endif
   if (!(s = getSelectedText())) {
     return "";
   }
diff --git a/xpdf-qt/XpdfWidget.cc b/xpdf-qt/XpdfWidget.cc
index 3be50d2..eced8ba 100644
--- a/xpdf-qt/XpdfWidget.cc
+++ b/xpdf-qt/XpdfWidget.cc
@@ -1526,7 +1526,11 @@ bool XpdfWidget::okToExtractText() const {
     if (!core->getDoc()) {
       return false;
     }
+#ifdef ENFORCE_PERMISSIONS
     return (bool)core->getDoc()->okToCopy();
+#else
+    return true;
+#endif
   } catch (GMemException e) {
     return false;
   }
diff --git a/xpdf/pdfimages.cc b/xpdf/pdfimages.cc
